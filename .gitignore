# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Data files
raw/csv/*.csv
raw/json/*.json
raw/pdf/*.pdf

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment and secrets
.env
.env.*
!.env.example

# Test, coverage, and type-check artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.pyre/
.ruff_cache/
.hypothesis/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Jupyter
.ipynb_checkpoints/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs and runtime artifacts
logs/*
!logs/.gitkeep
*.log

# Local Python version managers
.python-version
